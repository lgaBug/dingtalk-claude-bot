# DingTalk Stream Client Credentials
DINGTALK_CLIENT_ID=your_dingtalk_client_id
DINGTALK_CLIENT_SECRET=your_dingtalk_client_secret
DINGTALK_CARD_TEMPLATE_ID=your_card_template_id
PORT=3000

# DingTalk Robot Code (for MCP image tool)
DINGTALK_ROBOT_CODE=your_robot_code

# Claude CLI Process Name
# Bot will match/create a Claude CLI proxy with this name.
# Different bots can use different names to avoid conflicts.
CLAUDE_PROCESS_NAME=dingtalk-bot

# Claude CLI Working Directory
# The directory where Claude CLI will run (default: current directory).
# Example: /Users/username/projects/my-project
CLAUDE_WORKING_DIRECTORY=
